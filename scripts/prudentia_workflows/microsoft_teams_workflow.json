{
  "specification": "1. Go to 'https://teams.live.com/meet/<secret>meeting_code</secret>'.\n    2. If a consent, cookie, or welcome dialog appears, dismiss it.\n    3. If prompted to sign in, choose to join as a guest instead.\n    4. If a name input appears, type 'Netgent' and continue.\n    5. If any popup appears asking for microphone or camera access, dismiss or deny it.\n    6. Click 'Join now' (or equivalent button) to enter the meeting.\n    7. Wait for 10 seconds.\n    8. Leave the meeting by clicking the hang-up or leave button.",
  "states": [
    {
      "checks": [
        {
          "type": "always_true",
          "params": {}
        }
      ],
      "actions": [
        {
          "type": "go_to_url",
          "params": {
            "url": "https://teams.live.com/meet/{{meeting_code}}",
            "new_tab": false
          }
        },
        {
          "type": "click_element",
          "params": {
            "selector": "button.primary[aria-label=\"Join meeting from this browser\"]"
          }
        },
        {
          "type": "wait",
          "params": {
            "seconds": 10
          }
        },
        {
          "type": "input_text",
          "params": {
            "selector": "input.r12stul0.f1w2t2ij[placeholder=\"Type your name\"][type=\"text\"]",
            "text": "Netgent"
          }
        },
        {
          "type": "click_element",
          "params": {
            "selector": "button.fui-Button.r1f29ykk[id=\"prejoin-join-button\"][aria-label=\"Join now\"]"
          }
        },
        {
          "type": "wait",
          "params": {
            "seconds": 10
          }
        },
        {
          "type": "click_element",
          "params": {
            "selector": "button.fui-Button.r1f29ykk[id=\"hangup-button\"][type=\"button\"]"
          }
        }
      ],
      "end_state": "Workflow Completed",
      "executed": []
    }
  ],
  "parameters": [
    "meeting_code"
  ]
}
